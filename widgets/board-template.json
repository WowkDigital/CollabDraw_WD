{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "TextBlock",
      "text": "CoDraw Live",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Accent"
    },
    {
      "type": "Image",
      "url": "${boardImageUrl}",
      "altText": "Podgląd tablicy",
      "spacing": "Medium",
      "size": "Stretch",
      "style": "Default"
    },
    {
      "type": "TextBlock",
      "text": "${lastUpdated}",
      "size": "Small",
      "isSubtle": true,
      "wrap": true
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Otwórz CoDraw",
      "url": "${appUrl}"
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5"
}
